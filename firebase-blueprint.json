{
  "entities": {
    "SiteContent": {
      "title": "Site Content",
      "description": "Global website translations and configuration",
      "type": "object",
      "properties": {
        "translations": {
          "type": "object",
          "description": "Nested translation keys for BG and EN"
        },
        "pricingData": {
          "type": "array",
          "description": "Tariff records"
        },
        "taxiNumbers": {
          "type": "array",
          "description": "Available taxi phone numbers"
        },
        "seo": {
          "type": "object",
          "properties": {
            "title": { "type": "string" },
            "description": { "type": "string" },
            "keywords": { "type": "string" },
            "ogImage": { "type": "string" }
          }
        },
        "links": {
          "type": "object",
          "properties": {
            "facebook": { "type": "string" },
            "instagram": { "type": "string" },
            "twitter": { "type": "string" },
            "tiktok": { "type": "string" },
            "appleStore": { "type": "string" },
            "googlePlay": { "type": "string" }
          }
        },
        "updatedAt": {
          "type": "string",
          "format": "date-time"
        }
      },
      "required": ["translations", "pricingData", "taxiNumbers"]
    },
    "Analytics": {
      "title": "Analytics",
      "description": "Daily visit stats",
      "type": "object",
      "properties": {
        "totalVisits": { "type": "number" },
        "pages": { "type": "object" }
      }
    }
  },
  "firestore": {
    "config/site": {
      "schema": "SiteContent",
      "description": "Main website configuration document"
    },
    "analytics/{date}": {
      "schema": "Analytics",
      "description": "Daily visit data"
    }
  }
}
