rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    
    function isAdmin() {
      return isSignedIn() && exists(/databases/$(database)/documents/admins/$(request.auth.uid));
    }
    
    // Check if the admin system is empty
    function isFirstAdmin() {
      return isSignedIn() && !exists(/databases/$(database)/documents/config/system_status);
    }

    // Site Config - Publicly readable, admin writable
    match /config/site {
      allow read: if true;
      allow write: if isAdmin() || isFirstAdmin();
    }
    
    // System Status - Marker to check if system is initialized
    match /config/system_status {
      allow read: if true;
      allow create: if isSignedIn();
      allow update, delete: if isAdmin();
    }
    
    // Admins collection
    match /admins/{userId} {
      allow read: if isSignedIn() && (request.auth.uid == userId || isAdmin());
      allow create: if isFirstAdmin() || isAdmin();
      allow update: if isAdmin();
      allow delete: if isAdmin() && request.auth.uid != userId; // Prevent deleting self if possible (logic handled in app)
    }

    // Analytics - Anyone can write, admins can read/list
    match /analytics/{document=**} {
      allow read: if isAdmin();
      allow write: if true;
    }

    // Default deny for everything else
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
